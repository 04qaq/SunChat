# 复制本文件为 .env 后填写（.env 已被 git 忽略，勿提交）
# 启动：uv run run.py，默认监听 0.0.0.0:8000；浏览器打开 http://127.0.0.1:8000/（勿用 file:// 直接打开 html）
# 可选环境变量：HOST、PORT（与 LLM 无关，见 run.py）
# 心理引擎：src/app/prompts/psychology_profile.yaml（可用 PSYCHOLOGY_PROFILE_PATH 覆盖绝对路径）
# MBTI_INFER_TIMEOUT_S=40
# MBTI_ENGINE_ROOT=（默认 src/app/prompts/mbti_engine）
# MBTI_FOUNDATIONS_INFER_MAX_CHARS=4500
# MBTI_MAIN_FOUNDATIONS_MAX_CHARS=1200
# MBTI_PERSONA_MAX_CHARS=2800
# MBTI_JUDGE_PERSONA_EXCERPT_CHARS=420
# DeepSeek: https://platform.deepseek.com/

LLM_API_KEY=sk-replace-with-your-key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# 心情：true=评判模型输出 valence→0～100 指数；主模型结合 mood_injection.txt 与人设演绎（无 EMA）
# MOOD_USE_LLM_JUDGE=true
# MOOD_JUDGE_MAX_MESSAGES=12
# MOOD_JUDGE_TIMEOUT_S=45
# 每轮情感与助手输出 JSONL（默认 data/mood_trace/<session_id>.jsonl）
# MOOD_TRACE_ENABLED=true
# MOOD_TRACE_DIR=data/mood_trace
